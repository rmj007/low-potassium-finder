# Free USDA FoodData Central API key
# Register at: https://fdc.nal.usda.gov/api-key-signup.html
# If unset, the app uses DEMO_KEY (rate-limited: 30 req/hr per IP)
VITE_USDA_API_KEY=DEMO_KEY

# GitHub Pages base path — matches your repo name, e.g. /low-potassium-finder/
# Set in .env.production or as a GitHub Actions secret
# VITE_BASE_PATH=/low-potassium-finder/
